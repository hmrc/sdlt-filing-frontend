lease.typeOfLease.title                                                             = What is the type of lease?
lease.typeOfLease.heading                                                           = What is the type of lease?
lease.typeOfLease.R                                                                 = R - Residential
lease.typeOfLease.R.hintText                                                        = A building used, suitable for use, or being constructed as a dwelling, including the garden, grounds and any right of way
lease.typeOfLease.N                                                                 = N - Non-residential
lease.typeOfLease.N.hintText                                                        = Where the whole property is non-residential
lease.typeOfLease.M                                                                 = M - Mixed use
lease.typeOfLease.M.hintText                                                        = Where part of the property is residential
lease.typeOfLease.checkYourAnswersLabel                                             = Type of lease
lease.typeOfLease.error.required                                                    = Select the type of lease
lease.typeOfLease.change.hidden                                                     = Type of lease
lease.typeOfLease.error.invalid                                                     = Invalid Selection

lease.enterRentFreePeriod.title                                                     = Calculating the rent-free period
lease.enterRentFreePeriod.heading                                                   = Calculating the rent-free period
lease.enterRentFreePeriod.h2                                                        = How many months is the rent-free period?
lease.enterRentFreePeriod.p1                                                        = Enter the number of months for any period where the tenant will not have to pay rent. If the rent-free period is longer than 99 months, enter 99.
lease.enterRentFreePeriod.hint                                                      = Round the number of months up to a whole number, like 18
lease.enterRentFreePeriod.checkYourAnswersLabel                                     = Rent-free period (months)
lease.enterRentFreePeriod.error.required                                            = Enter the rent-free period
lease.enterRentFreePeriod.error.invalid                                             = The rent-free period must only include numbers 0 to 9
lease.enterRentFreePeriod.error.minValue                                            = The rent-free period must be at least one month
lease.enterRentFreePeriod.error.maxValue                                            = The rent-free period must be 99 months or fewer
lease.enterRentFreePeriod.error.maxLength                                           = The rent-free period must be 2 digits or less
lease.enterRentFreePeriod.change.hidden                                             = Rent-free period (months)

lease.laterRent.title                                                               = Later rent
lease.laterRent.heading                                                             = Later rent
lease.laterRent.subheading                                                          = Is the later rent known?
lease.laterRent.paragraph                                                           = This refers to any rent payable after the starting rent has ended. The later rent is only known if the full amount of all future rent payments is specified in the lease. If the rent is uncertain or no further rent is due, then the later rent is not known.
lease.laterRent.checkYourAnswersLabel                                               = Later rent known
lease.laterRent.error.required                                                      = Select yes if the later rent is known
lease.laterRent.change.hidden                                                       = Later rent known

lease.leaseStartDate.title                                                          = Lease start date
lease.leaseStartDate.heading                                                        = Lease start date
lease.leaseStartDate.subHeading                                                     = What is the start date as specified in the lease?
lease.leaseStartDate.hint                                                           = For example, 27 3 2023
lease.leaseStartDate.p                                                              = This date can be in the past or the future but must be entered exactly as specified in the lease. This is sometimes called the ‘term commencement date’.
lease.leaseStartDate.checkYourAnswersLabel                                          = Lease start date
lease.leaseStartDate.error.required.all                                             = Enter the start date as specified in the lease
lease.leaseStartDate.error.required.two                                             = The start date as specified in the lease must include {0} and {1}
lease.leaseStartDate.error.required                                                 = The start date as specified in the lease must include a {0}
lease.leaseStartDate.error.invalid                                                  = The start date as specified in the lease must be a real date
lease.leaseStartDate.change.hidden                                                  = Lease start date
lease.leaseStartDate.error.date.range.min                                           = The start date as specified in the lease must be the same as or after 1 January 1500
lease.leaseStartDate.error.leaseBeforeRentEndDate                                   = The start date as specified in the lease must be before the end date for starting rent
lease.leaseStartDate.error.leaseStartBeforeLeaseEndDate                             = The start date as specified in the lease must be before the end date as specified in the lease

lease.leaseThousandPoundsThreshold.title                                            = £1,000 threshold
lease.leaseThousandPoundsThreshold.heading                                          = £1,000 threshold
lease.leaseThousandPoundsThreshold.p                                                = This helps determine whether an SLDT return is required for the grant of a new lease. SDLT is only payable if:
lease.leaseThousandPoundsThreshold.li1                                              = the annual rent is £1,000 or more
lease.leaseThousandPoundsThreshold.li2                                              = the total premium (any payment other than rent) is £40,000 or more
lease.leaseThousandPoundsThreshold.subheading                                       = Is the annual rent £1,000 or more?
lease.leaseThousandPoundsThreshold.checkYourAnswersLabel                            = Annual rent £1,000 or more
lease.leaseThousandPoundsThreshold.error.required                                   = Select yes if the annual rent is £1,000 or more
lease.leaseThousandPoundsThreshold.change.hidden                                    = Annual rent £1,000 or more

lease.leaseStartingRentEndDate.title                                                = End of annual starting rent
lease.leaseStartingRentEndDate.heading                                              = End of annual starting rent
lease.leaseStartingRentEndDate.p1                                                   = This date will either be:
lease.leaseStartingRentEndDate.l1.li1                                               = the day before the first rent review
lease.leaseStartingRentEndDate.l1.li2                                               = the end of the fifth year of the lease term, if no review happens earlier
lease.leaseStartingRentEndDate.p2                                                   = If a lease has been surrendered, this date will typically be the effective date of the transaction.
lease.leaseStartingRentEndDate.subheading                                           = What is the end date for starting rent?
lease.leaseStartingRentEndDate.hint                                                 = For example, 27 3 2023
lease.leaseStartingRentEndDate.checkYourAnswersLabel                                = End of annual starting rent
lease.leaseStartingRentEndDate.error.required.all                                   = Enter the end date for starting rent
lease.leaseStartingRentEndDate.error.required.two                                   = The end date for starting rent must include a {0} and {1}
lease.leaseStartingRentEndDate.error.required                                       = The end date for starting rent must include a {0}
lease.leaseStartingRentEndDate.error.invalid                                        = The end date for starting rent must be a real date
lease.leaseStartingRentEndDate.error.date.range.min                                 = The end date for starting rent must be the same as or after 1 January 1900
lease.leaseStartingRentEndDate.error.afterLeaseStartDate                            = The end date for starting rent must be after the start date as specified in the lease
lease.leaseStartingRentEndDate.error.beforeLeaseEndDate                             = The end date for starting rent must be before the end date as specified in the lease
lease.leaseStartingRentEndDate.change.hidden                                        = End of annual starting rent

lease.doesLeaseIncludeRentFreePeriod.title                                          = Rent-free periods
lease.doesLeaseIncludeRentFreePeriod.heading                                        = Rent-free periods
lease.doesLeaseIncludeRentFreePeriod.checkYourAnswersLabel                          = Does the lease include a rent-free period?
lease.doesLeaseIncludeRentFreePeriod.paragraph                                      = This is when a tenant pays no rent for an agreed period, usually as an incentive to sign the lease or compensation to cover fit-out costs. Rent-free periods typically start on the effective date of transaction or the start date as specified in the lease, whichever is later.
lease.doesLeaseIncludeRentFreePeriod.subheading                                     = Does the lease include a rent-free period?
lease.doesLeaseIncludeRentFreePeriod.error.required                                 = Select yes if the lease includes a rent-free period
lease.doesLeaseIncludeRentFreePeriod.change.hidden                                  = Does the lease include a rent-free period?

lease.annualStartingRent.title                                                      = Annual starting rent
lease.annualStartingRent.heading                                                    = Annual starting rent
lease.annualStartingRent.subheading                                                 = What is the annual starting rent including VAT?
lease.annualStartingRent.hint                                                       = Enter the value in whole pounds only, for example £10,000
lease.annualStartingRent.p1                                                         = This is the annual rent payable on whichever date comes later:
lease.annualStartingRent.li1                                                        = the effective date of transaction
lease.annualStartingRent.li2                                                        = the start date as specified in the lease
lease.annualStartingRent.p2                                                         = You must include any VAT the landlord has opted to charge. If the rent is a token or nominal amount, like £1, or no rent is payable, enter ‘0’.
lease.annualStartingRent.details.summary                                            = About variable or uncertain rent
lease.annualStartingRent.details.content                                            = If the exact rent is uncertain (for example, linked to turnover), a reasonable estimate must be made. This should be based on available information, like a business plan or projected turnover, and used to calculate the Net Present Value (NPV) of the rent. Keep evidence of how the estimate was calculated in case requested by HMRC.
lease.annualStartingRent.checkYourAnswersLabel                                      = Annual starting rent
lease.annualStartingRent.error.required                                             = Enter the annual starting rent including VAT, in pounds
lease.annualStartingRent.error.invalidNumeric                                       = The annual starting rent including VAT must only include numbers 0 to 9 and commas
lease.annualStartingRent.error.invalidWholeNumber                                   = Enter the annual starting rent including VAT in whole pounds
lease.annualStartingRent.error.maximum                                              = The annual starting rent including VAT must be equal to or less than £99,999,999
lease.annualStartingRent.error.maxLength                                            = The annual starting rent including VAT must be 13 characters or fewer
lease.annualStartingRent.change.hidden                                              = Annual starting rent

lease.leaseIsVatPayable.title                                                       = Annual rent VAT
lease.leaseIsVatPayable.heading                                                     = Annual rent VAT
lease.leaseIsVatPayable.p                                                           = VAT is payable on commercial property rent when the landlord has made an "option to tax" election with HMRC. If VAT is payable, enter the total amount of VAT on both:
lease.leaseIsVatPayable.li1                                                         = the annual starting rent
lease.leaseIsVatPayable.li2                                                         = the total premium payable
lease.leaseIsVatPayable.subheading                                                  = Is VAT payable on the annual rent?
lease.leaseIsVatPayable.checkYourAnswersLabel                                       = Is VAT payable on the annual rent?
lease.leaseIsVatPayable.error.required                                              = Select yes if there is VAT payable on the annual rent
lease.leaseIsVatPayable.change.hidden                                               = Is VAT payable on the annual rent?

lease.enterAnnualRentVat.title                                                      = What is the total amount of VAT payable on the annual rent?
lease.enterAnnualRentVat.heading                                                    = What is the total amount of VAT payable on the annual rent?
lease.enterAnnualRentVat.hint                                                       = Enter the value in whole pounds only, for example £10,000
lease.enterAnnualRentVat.checkYourAnswersLabel                                      = Total VAT payable on the annual rent
lease.enterAnnualRentVat.error.required                                             = Enter the total amount of VAT payable on the annual rent, in pounds
lease.enterAnnualRentVat.error.invalidNumeric                                       = The total amount of VAT payable on the annual rent must only include numbers 0 to 9 and commas
lease.enterAnnualRentVat.error.invalidWholeNumber                                   = Enter the total amount of VAT payable on the annual rent in whole pounds
lease.enterAnnualRentVat.error.maximum                                              = The total amount of VAT payable on the annual rent must be equal to or less than £999,999,999
lease.enterAnnualRentVat.error.maxLength                                            = The total amount of VAT payable on the annual rent must be 14 digits or fewer
lease.enterAnnualRentVat.change.hidden                                              = Total VAT payable on the annual rent

lease.enterTotalPremiumPayable.title                                                = Calculating the total premium payable including VAT
lease.enterTotalPremiumPayable.heading                                              = Calculating the total premium payable including VAT
lease.enterTotalPremiumPayable.h2                                                   = What is the total premium payable including VAT?
lease.enterTotalPremiumPayable.p1                                                   = If this transaction is linked to the grant of any other lease, only enter the premium for this lease. Include any VAT due on this premium.
lease.enterTotalPremiumPayable.hint                                                 = Enter the value in whole pounds only, for example £10,000
lease.enterTotalPremiumPayable.checkYourAnswersLabel                                = Total premium payable including VAT
lease.enterTotalPremiumPayable.change.hidden                                        = Total premium payable including VAT
lease.enterTotalPremiumPayable.error.required                                       = Enter the total premium payable including VAT, in pounds
lease.enterTotalPremiumPayable.error.length                                         = The total premium payable including VAT must be 14 digits or fewer
lease.enterTotalPremiumPayable.error.invalidNumeric                                 = The total premium payable including VAT must only include numbers 0 to 9 and commas
lease.enterTotalPremiumPayable.error.invalidWholeNumber                             = Enter the total premium payable including VAT in whole pounds
lease.enterTotalPremiumPayable.error.maximum                                        = The total premium payable including VAT must be equal to or less than £9,999,999,999

lease.leaseEndDate.title                                                            = Lease end date
lease.leaseEndDate.heading                                                          = Lease end date
lease.leaseEndDate.heading.h2                                                       = What is the end date as specified in the lease?
lease.leaseEndDate.hint                                                             = For example, 27 3 2023
lease.leaseEndDate.p                                                                = This date must be entered exactly as specified in the lease. SDLT assumes that a lease runs its full term, so do not enter the break point or review date.
lease.leaseEndDate.details.summary                                                  = About long leases and periodic tenancies
lease.leaseEndDate.details.content                                                  = For a periodic tenancy, enter the date the first period ends, like the end of the first month or year. For long leases, where the lease ends after the year 9999, enter 31 12 9999 as the end date.
lease.leaseEndDate.checkYourAnswersLabel                                            = Lease end date
lease.leaseEndDate.error.required.all                                               = Enter the end date as specified in the lease
lease.leaseEndDate.error.required.two                                               = The end date as specified in the lease must include {0} and {1}
lease.leaseEndDate.error.required                                                   = The end date as specified in the lease must include a {0}
lease.leaseEndDate.error.invalid                                                    = The end date as specified in the lease must be a real date
lease.leaseEndDate.change.hidden                                                    = Lease end date
lease.leaseEndDate.error.date.range.min                                             = The end date as specified in the lease must be the same as or after 1 December 2003
lease.leaseEndDate.error.LeaseEndDateBeforeRentEndDate                              = The end date as specified in the lease must be after the end date for starting rent
lease.leaseEndDate.error.LeaseEndDateBeforeLeaseStartDate                           = The end date as specified in the lease must be after the start date as specified in the lease

lease.netPresentValue.title                                                         = Net present value (NPV)
lease.netPresentValue.heading                                                       = Net present value (NPV)
lease.netPresentValue.p1                                                            = This is the total value of all rent payments over the term of the lease, calculated at present-day prices. For SDLT purposes, the NPV is treated separately to any premium paid.
lease.netPresentValue.p2                                                            = Use the <a href="{0}" class="govuk-link" target="_blank" rel="noopener noreferrer">{1}</a>.
lease.netPresentValue.p2.linkText                                                   = SDLT calculator to work out the NPV (opens in new tab)
lease.netPresentValue.p2.link                                                       = https://www.gov.uk/guidance/stamp-duty-land-tax-leasehold-purchases#the-npv-of-the-rent-1
lease.netPresentValue.h2                                                            = What is the net present value upon which tax is calculated?
lease.netPresentValue.hint                                                          = Enter the value in whole pounds only, for example £10,000
lease.netPresentValue.checkYourAnswersLabel                                         = Net present value (NPV)
lease.netPresentValue.error.required                                                = Enter the net present value upon which tax is calculated, in pounds
lease.netPresentValue.error.length                                                  = The net present value upon which tax is calculated must be 16 digits or fewer
lease.netPresentValue.error.invalidNumeric                                          = The net present value upon which tax is calculated must only include numbers 0 to 9 and commas
lease.netPresentValue.error.invalidWholeNumber                                      = Enter the net present value upon which tax is calculated in whole pounds
lease.netPresentValue.error.maximum                                                 = The net present value upon which tax is calculated must be equal to or less than £9,999,999,999
lease.netPresentValue.change.hidden                                                 = Net present value (NPV)

submission.beforeYouStart.title                                                     = Before you start
submission.beforeYouStart.heading                                                   = Your return is ready for submission
submission.beforeYouStart.p1.text                                                   = You have now completed all sections of your SDLT return. You can {0}.
submission.beforeYouStart.p1.linkText                                               = view and print this return for your client’s approval before submitting (opens in new tab)
submission.beforeYouStart.p2                                                        = Once your return is submitted, you will receive:
submission.beforeYouStart.li1                                                       = a Unique Transaction Reference Number (UTRN)
submission.beforeYouStart.li2                                                       = an SDLT 5 certificate (the submission receipt)
submission.beforeYouStart.p3                                                        = You cannot amend your return online once it’s submitted.

submission.whoAreYouSubmittingFor.title                                             = Who are you submitting this return for?
submission.whoAreYouSubmittingFor.heading                                           = Who are you submitting this return for?
submission.whoAreYouSubmittingFor.purchaserAuthorised                               = The purchasers, who have authorised me to enter the effective date of the transaction
submission.whoAreYouSubmittingFor.purchaserApproved                                 = The purchasers, who have approved the effective date of the transaction
submission.whoAreYouSubmittingFor.myself                                            = Myself, or as the in-house representative of an organisation
submission.whoAreYouSubmittingFor.checkYourAnswersLabel                             = Who are you submitting this return for?
submission.whoAreYouSubmittingFor.error.required                                    = Select who you’re submitting this return for
submission.whoAreYouSubmittingFor.change.hidden                                     = Who are you submitting this return for?

submission.declaration.title                                                        = Declaration
submission.declaration.heading                                                      = Declaration
submission.declaration.purchasers.authorised.p1                                     = I confirm that all purchasers have:
submission.declaration.purchasers.authorised.bullet1                                = declared that the information in this return is correct and complete to the best of their knowledge, except for the effective date of the transaction
submission.declaration.purchasers.authorised.bullet2                                = authorised me to enter the effective date of the transaction and submit this return on their behalf
submission.declaration.purchasers.authorised.p2                                     = The effective date of the transaction is correct and accurate to the best of my knowledge.
submission.declaration.purchasers.approved.p1                                       = I confirm that all purchasers have:
submission.declaration.purchasers.approved.bullet1                                  = declared that the information in this return is correct and complete to the best of their knowledge
submission.declaration.purchasers.approved.bullet2                                  = authorised me to submit this return on their behalf
submission.declaration.purchasers.myself.p1                                         = The information in this return is correct and complete to the best of my knowledge.

submission.emailConfirmation.title                                                  = What email address should HMRC use to send confirmation?
submission.emailConfirmation.heading                                                = What email address should HMRC use to send confirmation?
submission.emailConfirmation.hint                                                   = HMRC will only use this email to send confirmation that this return has been successfully submitted
submission.emailConfirmation.error.required                                         = Enter the email address HMRC should use to send confirmation
submission.emailConfirmation.error.length                                           = The email address HMRC should use to send confirmation must be 36 characters or fewer
submission.emailConfirmation.error.invalid                                          = The email address HMRC should use to send confirmation must only include letters a to z, ampersands (&), at signs (@), forward slashes, full stops, hyphens, numbers 0-9, question marks and spaces
submission.emailConfirmation.error.invalidFormat                                    = Enter the email address HMRC should use to send confirmation in the correct format, like name@example.com
submission.emailConfirmation.change.hidden                                          = What email address should HMRC use to send confirmation?

submission.addEmailConfirmation.title                                               = Would you like an email confirmation once your return has been submitted? - Submit your return
submission.addEmailConfirmation.heading                                             = Would you like an email confirmation once your return has been submitted?
submission.addEmailConfirmation.hint                                                = If you select no, you will only be notified in the service if your return is approved immediately
submission.addEmailConfirmation.error.required                                      = Select yes if you would like an email confirmation once your return has been submitted

# ---- Cross-flow validation errors ----
crossflow.relief.heading                                                            = Update the reason for claiming relief
crossflow.relief.firstTimeBuyer.notResidential                                      = ‘32 - First Time Buyer’s Relief’ is only available when the property type is ‘01 - Residential’.
crossflow.relief.firstTimeBuyer.notResidential.inline                               = When claiming ‘32 - First Time Buyer’s Relief’, the type of property must be ‘01 - Residential’

crossflow.relief.multipleDwellings.notAllowedPropertyType                           = ‘33 - Multiple Dwellings Relief’ is not available when the property type is ‘03 - Non-residential’.
crossflow.relief.multipleDwellings.notAllowedPropertyType.inline                    = When claiming ‘33 - Multiple Dwellings Relief’, the type of property cannot be ‘03 - Non-residential’

# F28-500k — bullet layout
crossflow.relief.firstTimeBuyer.over500k.intro                                      = ‘32 - First Time Buyer’s Relief’ is only available when the total premium payable is £500,000 or less and the effective date of the transaction is either:
crossflow.relief.firstTimeBuyer.over500k.option1                                    = between 22 November 2017 and 22 September 2022
crossflow.relief.firstTimeBuyer.over500k.option2                                    = the same as or after 1 April 2025
crossflow.relief.firstTimeBuyer.over500k.outro                                      = Select a different reason for claiming relief.
crossflow.relief.firstTimeBuyer.over500k.inline                                     = When claiming ‘32 - First Time Buyer's Relief’, the total premium payable must be £500,000 or less and the effective date of the transaction must be between 22 November 2017 to 22 September 2022, or the same as or after 1 April 2025

# F28-625k — bullet layout
crossflow.relief.firstTimeBuyer.over625k.intro                                      = ‘32 - First Time Buyer’s Relief’ is only available when both:
crossflow.relief.firstTimeBuyer.over625k.option1                                    = the total premium payable is £625,000 or less
crossflow.relief.firstTimeBuyer.over625k.option2                                    = the effective date of the transaction is between 23 September 2022 and 31 March 2025
crossflow.relief.firstTimeBuyer.over625k.outro                                      = Select a different reason for claiming relief.
crossflow.relief.firstTimeBuyer.over625k.inline                                     = When claiming ‘32 - First Time Buyer's Relief’, the total premium payable must be £625,000 or less and the effective date of the transaction must be between 23 September 2022 and 31 March 2025

crossflow.relief.preCompletion.dateTooEarly                                         = This is a same journey error. just stub data so you can get to the page this would never trigger the "Need Review" status
crossflow.relief.preCompletion.dateTooEarly.inline                                  = When claiming ‘34 - Pre-completion transaction’ relief, the effective date of the transaction must be the same as or after 6 March 2013

crossflow.relief.firstTimeBuyer.over500k                                            = When claiming ‘32 - First Time Buyer’s Relief’, the total premium payable must be £500,000 or less and the effective date of the transaction must be between 22 November 2017 to 22 September 2022, or the same as or after 1 April 2025
crossflow.relief.firstTimeBuyer.over625k                                            = When claiming ‘32 - First Time Buyer’s Relief’, the total premium payable must be £625,000 or less and the effective date of the transaction must be between 23 September 2022 and 31 March 2025

crossflow.land.Cf-3.heading                                                         = Update the type of property
crossflow.land.Cf-3.body                                                            = When the type of property is ‘04 - Additional residential property liable to higher rate’, the effective date of the transaction cannot be before 1 April 2016.
crossflow.land.Cf-3.inline                                                          = When the type of property is ‘04 - Additional residential property liable to higher rate’, the effective date of the transaction must be the same as or after 1 April 2016

crossflow.land.cta.changePropertyType                                               = Select a different type of property.

# F23-35 — 15% rate of SDLT
crossflow.relief.fifteenPercentRate.dateTooEarly                                    = ‘35 - Relief from 17% rate of SDLT’ is only available when the effective date of the transaction is the same as or after 6 March 2013.
crossflow.relief.fifteenPercentRate.dateTooEarly.inline                             = When claiming ‘35 - Relief from 17% rate of SDLT’, the effective date of the transaction must be the same as or after 6 March 2013

# F23-36 — Freeport relief
crossflow.relief.freeport.outsideWindow                                             = ‘36 - Relief for Freeport tax site’ is only available when the effective date of the transaction is between 19 October 2021 and 30 September 2026.
crossflow.relief.freeport.outsideWindow.inline                                      = When claiming ‘36 - Relief for Freeport tax site’, the effective date of the transaction must be between 19 October 2021 and 30 September 2026

# F23-37 — Investment Zone relief
crossflow.relief.investmentZone.outsideWindow                                       = ‘37 - Relief for Investment Zone tax site’ is only available when the effective date of the transaction is between 29 September 2023 and 1 October 2034.
crossflow.relief.investmentZone.outsideWindow.inline                                = When claiming ‘37 - Relief for Investment Zone tax site’, the effective date of the transaction must be between 29 September 2023 and 1 October 2034

# F23-38 — Seeding relief
crossflow.relief.seeding.dateTooEarly                                               = ‘38 - Seeding Relief’ is only available when the effective date of the transaction is the same as or after 19 March 2025.
crossflow.relief.seeding.dateTooEarly.inline                                        = When claiming ‘38 - Seeding Relief’, the effective date of the transaction must be the same as or after 19 March 2025

# F25 — Multiple Dwellings Relief (effective date / contract date)
crossflow.relief.multipleDwellings.effectiveDateTooLate                             = ‘33 - Multiple Dwellings Relief’ is only available when the effective date of the transaction is before 1 June 2024.
crossflow.relief.multipleDwellings.effectiveDateTooLate.inline                      = When claiming ‘33 - Multiple Dwellings Relief’, the effective date of the transaction must be before 1 June 2024

crossflow.relief.multipleDwellings.contractDateTooLate                              = ‘33 - Multiple Dwellings Relief’ is only available when the date of contract is before 7 March 2024.
crossflow.relief.multipleDwellings.contractDateTooLate.inline                       = When claiming ‘33 - Multiple Dwellings Relief’, the date of contract must be before 7 March 2024
